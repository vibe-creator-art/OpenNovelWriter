DATABASE_URL="file:./dev.db"

# Optional. Recommended for production, but the app has a built-in fallback.
JWT_SECRET="change-this-in-production"

# Optional. If omitted, the app auto-generates and persists a secret in the data dir.
AI_CREDENTIALS_SECRET="change-this-too"

# Optional feature flags
NEXT_PUBLIC_ALLOW_REGISTER=true
ALLOW_REGISTER=true
SITE_BASIC_AUTH_ENABLED=false
SITE_BASIC_AUTH_USERNAME=
SITE_BASIC_AUTH_PASSWORD=
NEXT_PUBLIC_PRESET_AUTHORING=false
PRESET_AUTHORING=false

# Optional override for the app data directory
OPENNOVELWRITER_DATA_DIR=
